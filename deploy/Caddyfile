# Default: plain HTTP on port 80 (local dev).
# For production, set CADDY_DOMAIN to your real domain (e.g., aurex.example.com)
# and Caddy will automatically provision TLS via Let's Encrypt.
{$CADDY_DOMAIN::80} {
	# Security headers on ALL responses
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://unpkg.com https://cdn.jsdelivr.net; style-src 'self' https://cdn.jsdelivr.net 'unsafe-inline'; img-src 'self' https://*.googleusercontent.com data:; connect-src 'self' https://cdn.jsdelivr.net; font-src 'self';"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	# HSTS only over TLS (meaningless and incorrect over plain HTTP)
	@https protocol https
	header @https Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

	# Reverse proxy to FastAPI app
	reverse_proxy app:8000 {
		# Overwrite X-Forwarded-For to prevent client IP spoofing
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote_host}

		# Backend health monitoring
		health_uri /api/health
		health_interval 30s
		health_timeout 5s
	}

	# Request logging
	log {
		output stdout
		format json
	}
}
