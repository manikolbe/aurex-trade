# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Environment variables (never commit secrets)
.env

# Data & logs (runtime artifacts) — may contain PII: emails, OANDA account IDs,
# OAuth user IDs. NEVER commit. This is a PUBLIC repo.
data/
logs/

# Pulled production logs and any local analysis config holding identifiers.
# Belt-and-braces: logs/ already covers logs/prod/, but these are explicit so a
# stray copy elsewhere is still ignored.
**/prod-logs/
*.prod.log
analysis.local.*

