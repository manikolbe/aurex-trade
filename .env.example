# aurexTrade Configuration
# Copy this file to .env and adjust values as needed.
# NEVER commit the .env file — it is gitignored.

# --- Application ---
TRADING_MODE=local          # local | paper | live
SYMBOL=XAU_USD              # Trading instrument (XAU_USD = gold spot)
INTERVAL_SECONDS=60         # Main loop interval in seconds
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# --- OANDA Connection ---
# Generate your API token at: https://www.oanda.com/account/tpa/personal_token
# OANDA_ACCESS_TOKEN=         # Your OANDA API access token (NEVER commit this)
# OANDA_ACCOUNT_ID=           # Your OANDA account ID (e.g., 101-001-12345678-001)
OANDA_SERVER=practice         # "practice" or "live"

# --- Risk Management ---
RISK_MAX_POSITION_SIZE=10   # Maximum shares/units to hold
RISK_MAX_DAILY_LOSS=500.0   # Stop trading if daily P&L drops below this (USD)
RISK_MAX_TRADES_PER_DAY=10  # Maximum number of trades per day
RISK_KILL_SWITCH=false      # Emergency stop — set to true to halt all trading

# --- Strategy (SMA Crossover) ---
STRATEGY_SMA_SHORT_WINDOW=10    # Short-term SMA period (bars)
STRATEGY_SMA_LONG_WINDOW=30     # Long-term SMA period (bars)

# --- Database ---
DB_PATH=data/aurex_trade.db     # SQLite database path

# --- Authentication (Google OAuth) ---
# Create credentials at: https://console.cloud.google.com/apis/credentials
# AUTH_GOOGLE_CLIENT_ID=         # OAuth 2.0 Client ID (NEVER commit this)
# AUTH_GOOGLE_CLIENT_SECRET=     # OAuth 2.0 Client Secret (NEVER commit this)
AUTH_REDIRECT_URI=http://localhost:8000/auth/callback
AUTH_ALLOWED_EMAILS=manikolbe@gmail.com   # Comma-separated whitelist
AUTH_SESSION_EXPIRY_HOURS=48
AUTH_COOKIE_SECURE=false          # Set to true when using HTTPS in production
# AUTH_SECRET_KEY=                # Random string for CSRF state signing

# --- Live Trading Safety ---
# BOTH of these must be set to enable live trading.
# This is a deliberate double-gate to prevent accidental live trading.
# LIVE_TRADING_CONFIRMED=true
