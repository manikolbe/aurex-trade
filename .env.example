# aurexTrade Configuration
# Copy this file to .env and adjust values as needed.
# NEVER commit the .env file — it is gitignored.

# --- Application ---
TRADING_MODE=local          # local | paper | live
SYMBOL=GLD                  # Trading instrument (GLD = SPDR Gold ETF)
INTERVAL_SECONDS=60         # Main loop interval in seconds
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# --- IBKR Connection ---
# These are NOT credentials — just connection config for TWS/Gateway.
# Your IBKR username/password is entered into TWS/Gateway directly.
IBKR_HOST=127.0.0.1        # TWS/Gateway host (always localhost for local dev)
IBKR_PORT=7497              # 7497 = paper trading, 7496 = live trading
IBKR_CLIENT_ID=1            # Arbitrary integer; unique per concurrent connection

# --- Risk Management ---
RISK_MAX_POSITION_SIZE=10   # Maximum shares/units to hold
RISK_MAX_DAILY_LOSS=500.0   # Stop trading if daily P&L drops below this (USD)
RISK_MAX_TRADES_PER_DAY=10  # Maximum number of trades per day
RISK_KILL_SWITCH=false      # Emergency stop — set to true to halt all trading

# --- Strategy (SMA Crossover) ---
STRATEGY_SMA_SHORT_WINDOW=10    # Short-term SMA period (bars)
STRATEGY_SMA_LONG_WINDOW=30     # Long-term SMA period (bars)

# --- Database ---
DB_PATH=data/aurex_trade.db     # SQLite database path

# --- Live Trading Safety ---
# BOTH of these must be set to enable live trading.
# This is a deliberate double-gate to prevent accidental live trading.
# LIVE_TRADING_CONFIRMED=true
